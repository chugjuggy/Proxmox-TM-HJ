arch: amd64
cores: 4
dev0: /dev/dri/renderD128,gid=44
dev1: /dev/dri/card1,gid=44
features: nesting=1,keyctl=1
hostname: immich
memory: 6144
net0: name=eth0,bridge=vmbr0,gw=192.168.1.1,hwaddr=BC:24:11:57:40:56,ip=192.168.1.60/24,ip6=auto,type=veth
onboot: 1
ostype: debian
rootfs: bigSSD:vm-500-disk-0,size=500G
swap: 512
tags: community-script;photos
timezone: Europe/Zurich
unprivileged: 1
lxc.cgroup2.devices.allow: c 10:200 rwm
lxc.mount.entry: /dev/net/tun dev/net/tun none bind,create=file
